---
import { Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

const meta = {
  description: 'A personal website mirror based on the Axi Blog structure.',
  title: 'Home'
}
---

<PageLayout {meta}>
  <main class='mt-8 lg:mt-12'>
    <section class='animate grid gap-8 sm:grid-cols-[auto_1fr] sm:items-center'>
      <img
        src='/avatar/avatar.png'
        alt='Avatar'
        class='size-28 rounded-full border border-border object-cover sm:size-36'
      />
      <div>
        <h1 class='text-4xl font-semibold'>Axi</h1>
        <p class='mt-3 max-w-2xl text-muted-foreground'>
          Student and researcher interested in embodied AI, robotics, vision-language-action
          models, and practical engineering.
        </p>
        <div class='mt-5 flex flex-wrap gap-3 text-sm'>
          <a class='inline-flex items-center gap-2 hover:text-primary' href='/en/academic'>
            <Icon name='document' class='size-4' />
            Academic
          </a>
          <a class='inline-flex items-center gap-2 hover:text-primary' href='/en/projects'>
            <Icon name='link' class='size-4' />
            Projects
          </a>
          <a class='inline-flex items-center gap-2 hover:text-primary' href='/en/blog/research'>
            <Icon name='document' class='size-4' />
            Blog
          </a>
        </div>
      </div>
    </section>

    <section class='animate mt-14 grid gap-4 sm:grid-cols-4'>
      {
        [
          ['735', 'Days Online'],
          ['Jun 15, 2026', 'Last Updated'],
          ['38.2w', 'Total Words'],
          ['119', 'Total Posts']
        ].map(([value, label]) => (
          <div class='rounded-2xl border border-border bg-card p-4'>
            <div class='text-2xl font-semibold'>{value}</div>
            <div class='mt-1 text-sm text-muted-foreground'>{label}</div>
          </div>
        ))
      }
    </section>
  </main>
</PageLayout>
