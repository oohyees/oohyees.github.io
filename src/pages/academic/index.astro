---
import PageLayout from '@/layouts/CommonPage.astro'

const headings = [
  { depth: 2, slug: 'about-me', text: 'About Me' },
  { depth: 2, slug: 'research-interests', text: 'Research Interests' },
  { depth: 2, slug: 'publications', text: 'Publications' },
  { depth: 2, slug: 'open-source-projects', text: 'Open-source Projects' }
]

const publications = [
  {
    year: '2026',
    title: 'InternVLA-M1: Scaling Test-Time Compute for Vision-Language-Action Models',
    type: 'Preprint',
    status: 'Preprint',
    authors: 'InternVLA Team, Ning Gao, and collaborators',
    venue: 'arXiv',
    description:
      'A vision-language-action model exploring scalable test-time compute and data-centric embodied intelligence.',
    links: [
      ['ARXIV', 'https://arxiv.org/'],
      ['CODE', 'https://github.com/OpenRobotLab']
    ]
  },
  {
    year: '2025',
    title: 'GenManip: LLM-driven Simulation for Generalizable Instruction-Following Manipulation',
    type: 'Conference',
    status: 'Published',
    authors:
      'Ning Gao*, Yilun Chen*, Shuai Yang*, Xinyi Chen*, Yang Tian, Hao Li, Haifeng Huang, Hanqing Wang, Tai Wang, Jiangmiao Pang†',
    venue: 'Conference on Computer Vision and Pattern Recognition (CVPR) 2025',
    description:
      'GenManip is an LLM-driven, Isaac Sim-based embodied manipulation benchmark with automatic demonstration and layout generation and closed-loop evaluation.',
    links: [
      ['ARXIV', 'https://arxiv.org/abs/2506.10966'],
      ['WEBSITE', 'https://genmanip.axi404.top'],
      ['CODE', 'https://github.com/OpenRobotLab/GenManip'],
      ['VIDEO', 'https://youtu.be/FnoFvzVlM6E']
    ]
  },
  {
    year: '2024',
    title:
      'PMT: Progressive Mean Teacher via Exploring Temporal Consistency for Semi-Supervised Medical Image Segmentation',
    type: 'Conference',
    status: 'Published',
    authors: 'Ning Gao, Sanping Zhou†, Le Wang, Nanning Zheng',
    venue: 'European Conference on Computer Vision (ECCV) 2024',
    description:
      'A semi-supervised learning framework for medical image segmentation using Mean Teachers to enhance model diversity and regularization.',
    links: [
      ['SPRINGER', 'https://link.springer.com/chapter/10.1007/978-3-031-73113-6_9'],
      ['ARXIV', 'https://arxiv.org/abs/2409.05122'],
      ['CODE', 'https://github.com/Axi404/PMT']
    ]
  }
]

const byYear = publications.reduce<Record<string, typeof publications>>((acc, paper) => {
  acc[paper.year] = [...(acc[paper.year] ?? []), paper]
  return acc
}, {})
---

<PageLayout title='Academic' {headings} info={{ slug: '/academic', hideComment: true }}>
  <h2 id='about-me'>About Me</h2>
  <p>
    I am a senior student in the School of Artificial Intelligence / Qian Xuesen Honors College at
    Xi'an Jiaotong University. I am an incoming Ph.D. student in the joint program between Shanghai
    Jiao Tong University and the Shanghai Artificial Intelligence Laboratory, starting September
    2026 under the supervision of Research Scientist Jiangmiao Pang.
  </p>
  <p>
    My research philosophy is simple: I build things because it's fun.
  </p>
  <p>
    Currently, I co-lead StarVLA, an open-source Lego-like VLA framework adopted across the
    community, and lead the evaluation platform of InternVerse. I am a core contributor to
    InternVLA-M1 and to the InternData-M1 / InternData-A1 data initiatives, and the first author of
    GenManip (CVPR 2025).
  </p>

  <h2 id='research-interests'>Research Interests</h2>
  <div class='grid gap-3 sm:grid-cols-2'>
    {
      [
        'Vision-Language-Action models',
        'Embodied manipulation',
        'Simulation and evaluation',
        'Data-centric robot learning'
      ].map((item) => (
        <div class='rounded-xl border border-border bg-card p-4 text-sm text-muted-foreground'>
          {item}
        </div>
      ))
    }
  </div>

  <h2 id='publications'>Publications</h2>
  <div class='space-y-8'>
    {
      Object.entries(byYear)
        .sort(([a], [b]) => Number(b) - Number(a))
        .map(([year, papers]) => (
          <div>
            <p class='mb-4 text-xl font-semibold text-foreground'>{year}</p>
            <div class='space-y-4'>
              {papers.map((paper) => (
                <article class='group rounded-xl border border-border p-4 transition-all hover:border-foreground/25 hover:shadow-md'>
                  <p class='mb-2 mt-0 text-lg leading-snug text-foreground transition-colors group-hover:text-primary sm:text-xl'>
                    {paper.title}
                  </p>
                  <div class='mb-3 flex flex-wrap gap-2'>
                    <span class='rounded-full bg-sky-100 px-2.5 py-1 text-xs font-medium text-sky-800 dark:bg-sky-700 dark:text-sky-100'>
                      {paper.type}
                    </span>
                    <span class='rounded-full bg-green-100 px-2.5 py-1 text-xs font-medium text-green-800 dark:bg-green-700 dark:text-green-100'>
                      {paper.status}
                    </span>
                  </div>
                  <p class='mb-2 text-sm text-muted-foreground'>{paper.authors}</p>
                  <p class='mb-3 text-sm font-medium text-foreground'>{paper.venue}</p>
                  <p class='text-sm leading-relaxed text-muted-foreground'>{paper.description}</p>
                  <div class='mt-4 flex flex-wrap gap-2'>
                    {paper.links.map(([label, href]) => (
                      <a
                        href={href}
                        target='_blank'
                        rel='noopener noreferrer'
                        class='rounded-md bg-muted px-3 py-1.5 text-xs font-medium text-muted-foreground no-underline transition-all hover:bg-muted/80 hover:text-foreground'
                      >
                        {label}
                      </a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
    }
  </div>

  <h2 id='open-source-projects'>Open-source Projects</h2>
  <div class='grid gap-3 sm:grid-cols-2'>
    <a class='rounded-xl border border-border bg-card p-4 no-underline transition-all hover:border-foreground/25 hover:shadow-md' href='https://github.com/InternRobotics/InternVLA' target='_blank'>
      <p class='m-0 font-medium text-foreground'>InternVLA / StarVLA</p>
      <p class='m-0 mt-2 text-sm text-muted-foreground'>Open-source VLA infrastructure for embodied AI research.</p>
    </a>
    <a class='rounded-xl border border-border bg-card p-4 no-underline transition-all hover:border-foreground/25 hover:shadow-md' href='https://github.com/OpenRobotLab/GenManip' target='_blank'>
      <p class='m-0 font-medium text-foreground'>GenManip</p>
      <p class='m-0 mt-2 text-sm text-muted-foreground'>LLM-driven simulation benchmark for instruction-following manipulation.</p>
    </a>
  </div>
</PageLayout>
